<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jaipuriya Kurti Bazaar</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
:root{
--primary:#7B3F00;
--accent:#F4A261;
--light:#fff8f2;
--dark:#222;
--success:#2a9d8f;
}

*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}
body{background:var(--light);color:var(--dark);scroll-behavior:smooth;}
header{
background:#fff;
padding:15px;
text-align:center;
box-shadow:0 2px 8px rgba(0,0,0,0.08);
position:sticky;top:0;z-index:1000;
}
header h1{font-size:22px;color:var(--primary);}
header p{font-size:14px;color:#666;}

.hero{
background:url('https://i.ibb.co/bg2fV7LN') center/cover no-repeat;
height:70vh;
display:flex;
align-items:center;
justify-content:center;
flex-direction:column;
color:white;
text-align:center;
position:relative;
}
.hero::after{
content:'';
position:absolute;
top:0;left:0;right:0;bottom:0;
background:rgba(0,0,0,0.5);
}
.hero h2{
position:relative;
font-size:28px;
margin-bottom:20px;
}
.hero button{
position:relative;
padding:12px 25px;
border:none;
background:var(--accent);
color:white;
font-weight:600;
border-radius:30px;
cursor:pointer;
transition:0.3s;
}
.hero button:hover{background:var(--primary);}

.filters{
display:flex;
overflow-x:auto;
gap:10px;
padding:15px;
}
.filters button{
padding:8px 15px;
border:none;
border-radius:20px;
background:#eee;
cursor:pointer;
}
.filters button.active{background:var(--primary);color:white;}

.products{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
gap:15px;
padding:15px;
}
.card{
background:white;
border-radius:12px;
box-shadow:0 3px 10px rgba(0,0,0,0.08);
overflow:hidden;
display:flex;
flex-direction:column;
transition:0.3s;
}
.card img{width:100%;height:180px;object-fit:cover;}
.card-body{padding:10px;flex-grow:1;}
.card h3{font-size:14px;margin-bottom:5px;}
.price{font-weight:600;margin-bottom:10px;}
.card button{
width:100%;
padding:8px;
border:none;
background:var(--primary);
color:white;
border-radius:6px;
cursor:pointer;
}

.cart-icon{
position:fixed;
bottom:20px;right:20px;
background:var(--primary);
color:white;
padding:15px;
border-radius:50%;
cursor:pointer;
z-index:2000;
}
.cart-icon span{
background:red;
border-radius:50%;
padding:2px 6px;
font-size:12px;
position:absolute;
top:-5px;right:-5px;
}

.cart-modal{
position:fixed;
top:0;right:-100%;
width:100%;max-width:400px;
height:100%;
background:white;
box-shadow:-3px 0 15px rgba(0,0,0,0.2);
padding:20px;
overflow-y:auto;
transition:0.4s;
z-index:3000;
}
.cart-modal.active{right:0;}

.cart-item{
border-bottom:1px solid #eee;
padding:10px 0;
}
.qty{
display:flex;gap:10px;align-items:center;
}
.qty button{padding:3px 8px;}
.total{
font-size:18px;font-weight:700;margin-top:15px;
}
.checkout-btn{
margin-top:15px;
padding:10px;
width:100%;
border:none;
background:var(--success);
color:white;
border-radius:6px;
cursor:pointer;
}

form{
margin-top:20px;
display:none;
flex-direction:column;
gap:10px;
}
form input,form textarea{
padding:8px;
border-radius:6px;
border:1px solid #ccc;
}
form button{
background:var(--primary);
color:white;
padding:10px;
border:none;
border-radius:6px;
cursor:pointer;
}

.whatsapp{
position:fixed;
bottom:20px;left:20px;
background:#25D366;
color:white;
padding:12px 15px;
border-radius:30px;
text-decoration:none;
font-size:14px;
}
.confirmation{
display:none;
margin-top:15px;
color:green;
font-weight:600;
}
</style>
</head>
<body>

<header>
<h1>Jaipuriya Kurti Bazaar</h1>
<p>Old city vibes delivered to your door</p>
</header>

<section class="hero">
<h2>Shop Authentic Style from Bapu Bazaar</h2>
<button onclick="document.querySelector('.products').scrollIntoView()">Shop Now</button>
</section>

<div class="filters">
<button class="active" onclick="filterProducts('All')">All</button>
<button onclick="filterProducts('Gifts')">Gifts</button>
<button onclick="filterProducts('Kurti')">Kurti</button>
<button onclick="filterProducts('Bangles')">Bangles</button>
<button onclick="filterProducts('Jhumkas')">Jhumkas</button>
</div>

<div class="products" id="products"></div>

<div class="cart-icon" onclick="toggleCart()">🛒<span id="cart-count">0</span></div>

<div class="cart-modal" id="cart">
<h2>Your Cart</h2>
<div id="cart-items"></div>
<div class="total">Total: ₹ <span id="grand-total">0</span></div>
<button class="checkout-btn" onclick="showForm()">Place Order</button>

<form id="order-form" action="https://formspree.io/f/xqedoqad" method="POST">
<input type="hidden" name="order_summary" id="order-summary">
<input type="text" name="Customer Name" placeholder="Your Name" required>
<input type="text" name="Phone Number" placeholder="Phone Number" required>
<textarea name="Delivery Address" placeholder="Delivery Address" required></textarea>
<textarea name="Special Instructions" placeholder="Any Special Instructions"></textarea>
<button type="submit">Submit Order</button>
</form>

<div class="confirmation">
Order placed successfully! Jaipuriya Kurti Bazaar will contact you on WhatsApp to confirm.
<br><br>
<a href="https://wa.link/yl33oz" target="_blank">Click here to message on WhatsApp</a>
</div>

</div>

<a href="https://wa.me/918249257345" class="whatsapp" target="_blank">Chat on WhatsApp</a>

<script>
const products=[
{id:1,name:"Name Wallet",price:299,category:"Gifts",image:"https://i.ibb.co/MyTFZ6DL",desc:"Customized Name wallet"},
{id:2,name:"Wireless HP Mouse",price:359,category:"Gifts",image:"https://i.ibb.co/b5tHdF7s",desc:"Premium Mouse"},
{id:3,name:"Bellavita Vanilla Unisex Perfume",price:459,category:"Gifts",image:"https://i.ibb.co/zHD1p1W7",desc:"Long Lasting Perfume"},
{id:4,name:"Fastrack Watch",price:759,category:"Gifts",image:"https://i.ibb.co/Nd7tDKbK",desc:"Premium Watch"},
{id:5,name:"Anarkali Kurti",price:759,category:"Kurti",image:"https://i.ibb.co/Q7kdZ1mG",desc:"Yellow Kurti for Haldi/Puja"},
];

let cart=JSON.parse(localStorage.getItem("cart"))||[];

function renderProducts(list){
const container=document.getElementById("products");
container.innerHTML="";
list.forEach(p=>{
container.innerHTML+=`
<div class="card">
<img src="${p.image}" loading="lazy" alt="${p.desc}">
<div class="card-body">
<h3>${p.name}</h3>
<div class="price">₹ ${p.price}</div>
<button onclick="addToCart(${p.id})">Add to Cart</button>
</div>
</div>`;
});
}
renderProducts(products);

function filterProducts(cat){
document.querySelectorAll(".filters button").forEach(b=>b.classList.remove("active"));
event.target.classList.add("active");
if(cat==="All") renderProducts(products);
else renderProducts(products.filter(p=>p.category===cat));
}

function addToCart(id){
const item=cart.find(i=>i.id===id);
if(item)item.qty++;
else cart.push({...products.find(p=>p.id===id),qty:1});
saveCart();
}

function saveCart(){
localStorage.setItem("cart",JSON.stringify(cart));
updateCart();
}

function updateCart(){
document.getElementById("cart-count").innerText=cart.reduce((a,b)=>a+b.qty,0);
const container=document.getElementById("cart-items");
container.innerHTML="";
let total=0;
cart.forEach((item,index)=>{
total+=item.price*item.qty;
container.innerHTML+=`
<div class="cart-item">
<strong>${item.name}</strong><br>
₹ ${item.price} x ${item.qty} = ₹ ${item.price*item.qty}
<div class="qty">
<button onclick="changeQty(${index},-1)">-</button>
<button onclick="changeQty(${index},1)">+</button>
<button onclick="removeItem(${index})">Remove</button>
</div>
</div>`;
});
document.getElementById("grand-total").innerText=total;
}
updateCart();

function changeQty(i,val){
cart[i].qty+=val;
if(cart[i].qty<=0)cart.splice(i,1);
saveCart();
}
function removeItem(i){
cart.splice(i,1);
saveCart();
}

function toggleCart(){
document.getElementById("cart").classList.toggle("active");
}

function showForm(){
document.getElementById("order-form").style.display="flex";
}

document.getElementById("order-form").addEventListener("submit",function(e){
let summary="";
let total=0;
cart.forEach(item=>{
summary+=`${item.name} - ${item.qty} x ₹${item.price} = ₹${item.qty*item.price}\n`;
total+=item.qty*item.price;
});
summary+="\nGrand Total: ₹"+total;
document.getElementById("order-summary").value=summary;

setTimeout(()=>{
cart=[];
saveCart();
document.querySelector(".confirmation").style.display="block";
},500);
});
</script>

</body>
</html>
